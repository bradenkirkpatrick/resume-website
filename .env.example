# Resume Website Configuration
# Copy this file to .env and update the values.

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Docs Integration (optional)
# Populates resume from a Google Doc. Works with publicly shared docs (no API key needed).
# See deploy-ec2.md for setting up API access for private docs.
GOOGLE_DOCS_ID=1IvKov91tVgnB4mHLVjz1s18q9OJnNeWyh3mNsmG3n84
# Only needed if the doc is NOT publicly shared:
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend Configuration
FRONTEND_PORT_LOCAL=5173
FRONTEND_PORT_PROD=3000

# Production Configuration
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-this-to-a-random-secret-key
